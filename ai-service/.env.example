# =====================================================================
# FactoryGuard AI Service — environment variables
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# ---------- LLM ----------
# Provider switch: "ollama" (local dev) | "openai" (production / demo swap)
LLM_PROVIDER=ollama

# Ollama runtime
OLLAMA_BASE_URL=http://localhost:11434
# Dev box uses qwen2.5:3b for KPI runs (qwen3.5:9b was too slow on this
# hardware — see project_qwen3_no_think memory).
OLLAMA_MODEL=qwen2.5:3b
# Keep the embedding/LLM models loaded so the first request after a
# quiet period doesn't pay the model-load cost (drops latency P95).
# This is read by the Ollama server process, not the client — set it in
# the environment that launches `ollama serve`.
# OLLAMA_KEEP_ALIVE=24h

# OpenAI runtime (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Embeddings ----------
# Provider switch: "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
# OpenAI embedding model (used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Database (pgvector) ----------
DATABASE_URL=postgresql+psycopg://factoryguard:factoryguard@localhost:5432/factoryguard

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# =====================================================================
# FactoryGuard AI Service — environment variables
# Copy to .env and fill in real values. Never commit .env.
# =====================================================================

# ---------- LLM ----------
# Provider switch: "ollama" (local dev) | "openai" (production / demo swap)
LLM_PROVIDER=ollama

# Ollama runtime
OLLAMA_BASE_URL=http://localhost:11434
# Local default. WBS originally specified qwen3:8b; this project uses
# qwen3.5:9b which is already pulled on the dev machine.
OLLAMA_MODEL=qwen3.5:9b

# OpenAI runtime (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Embeddings ----------
# Provider switch: "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
# OpenAI embedding model (used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Database (pgvector) ----------
DATABASE_URL=postgresql+psycopg://factoryguard:factoryguard@localhost:5432/factoryguard

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
